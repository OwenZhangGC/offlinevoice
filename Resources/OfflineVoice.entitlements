<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required so audio recording keeps working once the Hardened Runtime is
	     enabled during Developer ID signing. The app is not sandboxed; pasting
	     (synthetic key events) and the hotkey monitor are gated by the
	     Accessibility / Input Monitoring TCC prompts, not by entitlements. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
